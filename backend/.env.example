# Copy to .env and adjust. All values are optional in dev (defaults to SQLite).
#
# Remote Postgres (Neon): paste the connection string from your Neon project's
# "Connection Details". Keep the ?sslmode=require — Neon requires SSL.
# DATABASE_URL=postgresql://<user>:<password>@<endpoint>.<region>.aws.neon.tech/<db>?sslmode=require
#
# Generic Postgres:
# DATABASE_URL=postgresql://user:pass@localhost:5432/stringing
# SECRET_KEY=change-me-in-prod
# Secret code required to create a stringer account (empty = stringer signup off).
# STRINGER_SIGNUP_CODE=some-long-random-value
# ACCESS_TOKEN_EXPIRE_MINUTES=1440
# OPEN_TIME=09:00
# CLOSE_TIME=18:00
# SLOT_MINUTES=30
# TURNAROUND_NOTE=Most racquets are ready within a day, depending on the current queue.
# DROP_OFF_ADDRESS=123 Court Lane, Atlanta, GA 30303
# CORS_ORIGINS=http://localhost:5173
# CREATE_ALL_ON_STARTUP=false
